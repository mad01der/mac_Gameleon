{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Task(*)",
      "NotebookEdit(*)",
      "Skill(*)",
      "Agent(*)",
      "Bash(*)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(rm -rf ~)*",
      "Bash(rm -rf /*)*",
      "Bash(sudo rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(mkfs *)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(:(){ :|:& };:)*",
      "Bash(> /dev/sda*)",
      "Bash(curl * | sh)*",
      "Bash(curl * | bash)*",
      "Bash(wget * | sh)*",
      "Bash(wget * | bash)*",
      "Bash(chmod 777 *)",
      "Bash(chown -R *)",
      "Bash(pkill -9 *)",
      "Bash(killall *)"
    ]
  }
}
